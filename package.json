{
  "name": "talentscout",
  "version": "1.0.0",
  "description": "Football scouting simulation game",
  "author": {
    "name": "TalentScout Games",
    "email": "dev@talentscout.game"
  },
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "clean:build": "node scripts/clean-build-output.mjs",
    "build": "node scripts/build-production.mjs",
    "build:e2e": "node scripts/build-e2e.mjs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit --incremental false",
    "electron:dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron electron/main.js --dev\"",
    "electron:prepare": "node scripts/prepare-electron-package.mjs",
    "electron:assert-slim-package": "node scripts/assert-packaged-runtime-slim.mjs",
    "electron:test-windows-runtime": "node scripts/run-windows-packaged-runtime-check.mjs",
    "electron:build": "npm run build && npm run electron:prepare && electron-builder && npm run electron:assert-slim-package",
    "electron:dist": "npm run build && npm run electron:prepare && electron-builder --publish never && npm run electron:assert-slim-package",
    "test:e2e": "playwright test",
    "e2e:serve": "node scripts/serve-static.mjs --dir out-e2e --port 3000 --require-e2e-bridge",
    "test:unit": "vitest run",
    "test:coverage:critical": "vitest run --config vitest.critical-coverage.config.ts",
    "test:coverage:retention": "vitest run --config vitest.retention-coverage.config.ts",
    "test:replayability": "node scripts/run-replayability-telemetry.mjs --seeds=100 --seasons=3 --weeks=38 --out=artifacts/release/generated/replayability-release-summary.json",
    "test:replayability:nightly": "node scripts/run-replayability-telemetry.mjs --profile=nightly --seeds=1000 --seasons=10 --weeks=38 --out=artifacts/replayability/nightly-summary.json",
    "test:release-soak": "node scripts/run-long-career-release-soak.mjs",
    "test:release-soak:worker": "vitest run --config vitest.release-soak.config.ts",
    "test:asset-provenance": "node scripts/audit-asset-provenance.mjs",
    "audit:asset-provenance": "node scripts/audit-asset-provenance.mjs --report-only",
    "release:package-manifest": "node scripts/create-release-package-manifest.mjs",
    "release:recover-soak-lease": "node scripts/recover-long-career-soak-lease.mjs",
    "test:release-evidence": "node scripts/check-release-evidence.mjs",
    "audit:release-evidence": "node scripts/check-release-evidence.mjs --report-only",
    "audit:architecture": "node scripts/analyze-architecture.mjs",
    "test:architecture": "node scripts/analyze-architecture.mjs --check",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:smoke": "playwright test e2e/regression/smoke.spec.ts",
    "test:e2e:accessibility": "playwright test e2e/accessibility/youth-ea-accessibility.spec.ts",
    "test:e2e:performance": "playwright test e2e/performance/low-end-runtime.spec.ts --workers=1 --retries=0",
    "test:e2e:opening": "playwright test e2e/flows/opening-discovery-hook.spec.ts --workers=1",
    "test:e2e:youth-ea": "node scripts/run-youth-ea-e2e.mjs",
    "test:e2e:soak": "playwright test e2e/regression/long-career-invariants.spec.ts --workers=1"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.40.0",
    "@supabase/supabase-js": "^2.97.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.3.0",
    "framer-motion": "^12.34.3",
    "howler": "^2.2.4",
    "lucide-react": "^0.575.0",
    "next": "^15.5.12",
    "next-intl": "^4.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "steamworks.js": "^0.4.0",
    "styled-jsx": "^5.1.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@electron/notarize": "^3.1.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/howler": "^2.2.12",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.5",
    "eslint-config-next": "^15.5.12",
    "fake-indexeddb": "^6.2.5",
    "proper-lockfile": "4.1.2",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
