<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- V8 JIT compilation — required for all Electron / Chromium apps. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Chromium renderer requires writable + executable memory pages. -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Outbound network: feedback and opt-in error telemetry. -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Save / load file dialogs initiated by the user. -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
