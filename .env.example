NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Fail-closed. Enable only after production feedback RLS, abuse throttling,
# retention, and monitoring have been certified for this exact build.
NEXT_PUBLIC_ENABLE_ONLINE_FEEDBACK=false

# Required for production error reporting — get from Sentry project settings
NEXT_PUBLIC_SENTRY_DSN=

# Set to "true" to enable demo mode (limits gameplay to early seasons)
NEXT_PUBLIC_DEMO=

ELEVENLABS_API_KEY=your-api-key
